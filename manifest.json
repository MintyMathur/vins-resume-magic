{
  "manifest_version": 3,
  "name": "Vin's Resume Magic",
  "version": "1.0.0",
  "description": "Magically tailor your resume to match any job description with 90%+ ATS accuracy.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "https://api.mistral.ai/*"],
  "action": {
    "default_title": "Open Vin's Resume Magic"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
